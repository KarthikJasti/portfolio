---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" sideBarActiveItemID="contact">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Get in Touch</div>
  </div>

  <div class="mb-10">
    <p class="text-lg mb-8 leading-relaxed">
      I'm always interested in new projects, collaborations, and opportunities. Feel free to reach out through any of these channels.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
    <div class="card bg-base-200 p-6">
      <div class="text-2xl font-bold mb-2">Email</div>
      <a href="mailto:karthikjasti08@gmail.com" class="text-primary hover:underline text-lg">
        karthikjasti08@gmail.com
      </a>
    </div>

    <div class="card bg-base-200 p-6">
      <div class="text-2xl font-bold mb-2">LinkedIn</div>
      <a href="https://www.linkedin.com/in/karthikjasti" target="_blank" class="text-primary hover:underline text-lg">
        linkedin.com/in/karthikjasti
      </a>
    </div>

    <div class="card bg-base-200 p-6">
      <div class="text-2xl font-bold mb-2">GitHub</div>
      <a href="https://github.com/KarthikJasti" target="_blank" class="text-primary hover:underline text-lg">
        github.com/KarthikJasti
      </a>
    </div>

    <div class="card bg-base-200 p-6">
      <div class="text-2xl font-bold mb-2">Instagram</div>
      <a href="https://instagram.com/k.jasti" target="_blank" class="text-primary hover:underline text-lg">
        @k.jasti
      </a>
    </div>
  </div>

  <div class="mb-10">
    <div class="text-2xl font-bold mb-4">Quick Response</div>
    <p class="text-lg">
      Best way to reach me is email. I typically respond within 24 hours.
    </p>
  </div>
</BaseLayout>